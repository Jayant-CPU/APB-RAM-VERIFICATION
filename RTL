// APB RAM DUT

module apb_ram (
    input  logic        PRESETn,
    input  logic        PCLK,
    input  logic        PSEL,
    input  logic        PENABLE,
    input  logic        PWRITE,
    input  logic [31:0] PADDR,
    input  logic [31:0] PWDATA,

    output logic [31:0] PRDATA,
    output logic        PREADY,
    output logic        PSLVERR
);

    // Memory
    logic [31:0] mem [0:31];

    // APB FSM
    typedef enum logic [1:0] {
        IDLE,
        SETUP,
        ACCESS
    } state_type;

    state_type state;

    // Registered PREADY
    always_ff @(posedge PCLK or negedge PRESETn) begin

        if (!PRESETn)
            PREADY <= 1'b0;

        else begin
            case(state)
                IDLE   : PREADY <= 1'b0;
                SETUP  : PREADY <= 1'b0;
                ACCESS : PREADY <= 1'b1;
                default: PREADY <= 1'b0;
            endcase
        end
    end

    // Main FSM + Memory Access
    always_ff @(posedge PCLK or negedge PRESETn) begin
        if (!PRESETn) begin
            state    <= IDLE;
            PRDATA   <= 32'd0;
            PSLVERR  <= 1'b0;
            for (int i = 0; i < 32; i++)
                mem[i] <= 32'd0;
        end
        else begin
            case(state)
                // IDLE
                IDLE: begin
                    PSLVERR <= 1'b0;
                    if (PSEL && !PENABLE)
                        state <= SETUP;
                end

                // SETUP
                SETUP: begin
                    if (PSEL && PENABLE)
                        state <= ACCESS;
                end

                // ACCESS
                ACCESS: begin
                    // default outputs
                    PSLVERR <= 1'b0;
                    // valid address check
                    if ((PADDR < 32'd128) &&
                        (PADDR[1:0] == 2'b00)) begin
                        // WRITE
                        if (PWRITE) begin
                            mem[PADDR[6:2]] <= PWDATA;
                        end
                        // READ
                        else begin
                            PRDATA <= mem[PADDR[6:2]];
                        end
                    end
                    // INVALID ADDRESS
                    else begin
                        PSLVERR <= 1'b1;
                    end
                    // APB transfer completes when master removes PSEL
                    if (!PSEL)
                        state <= IDLE;
                end

                // DEFAULT
                default: begin
                    state <= IDLE;
                end
            endcase
        end
    end
endmodule
